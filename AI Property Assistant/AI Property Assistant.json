      "parameters": {
        "jsCode": "// Step 1: Get updatedState directly (already an object, no parsing needed)\nconst updatedState = $('AI Agent1').first().json.output.updatedState;\n\n// Step 2: Remove empty, null, 0, and blank string values\nconst filtered = Object.fromEntries(\n  Object.entries(updatedState).filter(([key, value]) => {\n    if (value === null || value === undefined) return false;\n    if (value === 0) return false;\n    if (value === '') return false;\n    return true;\n  })\n);\n\n// Step 3: Return only meaningful fields\nreturn [{\n  json: filtered\n}];"
      },
