    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst sessionId = $input.first().json.sessionId;\n\nif (!staticData.userState) staticData.userState = {};\nif (!staticData.cache) staticData.cache = {};\n\nif (!staticData.userState[sessionId]) {\n  staticData.userState[sessionId] = {\n    property_type: \"\",\n    min_price: 0,\n    max_price: 0,\n    city: \"\",\n    state: \"\",\n    availability: \"\",\n    bedrooms: 0\n  };\n}\n\nif (!staticData.cache[sessionId]) {\n  staticData.cache[sessionId] = {};\n}\n\nconst currentState = JSON.parse(JSON.stringify(staticData.userState[sessionId]));\n\nreturn [{\n  json: {\n    sessionId: sessionId,\n    userMessage: $input.first().json.chatInput,\n    currentState: currentState,\n    cache: staticData.cache[sessionId]\n  }\n}];"
      },
