    {
      "parameters": {
        "jsCode": "const data = $input.all().map(i => i.json);\n\n// Get results\nlet results = [];\nif (data.length === 1 && data[0].results) {\n  results = data[0].results;\n} else {\n  results = data.filter(d => d.id !== undefined);\n}\n\n// Get property_type and city from results\nconst propertyType = results[0]?.property_type || 'Property';\nconst cityName = results[0]?.city || 'your area';\n\n// Get price range from Data table row\nconst rowData = $('Get row(s)').first().json;\nconst minPrice = rowData.min_price || 0;\nconst maxPrice = rowData.max_price || 0;\nconst sessionId = rowData.sessionid;\n\n// Cache logic\nconst staticData = $getWorkflowStaticData('global');\nconst cityKey = cityName.toLowerCase();\n\nif (cityKey && results.length > 0) {\n  if (!staticData.cache) staticData.cache = {};\n  if (!staticData.cache[sessionId]) staticData.cache[sessionId] = {};\n  staticData.cache[sessionId][cityKey] = results;\n}\n\n// No results\nif (results.length === 0) {\n  return [{\n    json: {\n      output: `I couldn't find any ${propertyType} in ${cityName} matching your criteria. Try adjusting your budget or location!`\n    }\n  }];\n}\n\n// Build reply message\nlet msg = `Great news! I found ${results.length} ${propertyType}(s) in ${cityName}`;\n\nif (minPrice > 0 || maxPrice > 0) {\n  msg += ` within your budget`;\n  if (minPrice > 0 && maxPrice > 0) msg += ` ($${minPrice} - $${maxPrice})`;\n  else if (maxPrice > 0) msg += ` (up to $${maxPrice})`;\n  else msg += ` (from $${minPrice})`;\n}\nmsg += `:\\n\\n`;\n\nresults.forEach((p, i) => {\n  msg += `🏠 Option ${i + 1}:\\n`;\n  msg += `   Type: ${p.property_type}\\n`;\n  msg += `   Price: $${p.price}/month\\n`;\n  msg += `   City: ${p.city}\\n`;\n  msg += `   Bedrooms: ${p.bedrooms} bed\\n`;\n  if (p.amenities && p.amenities.length) {\n    msg += `   Amenities: ${p.amenities.join(', ')}\\n`;\n  }\n  msg += `\\n`;\n});\n\nmsg += `Would you like to refine your search or see more details?`;\n\nreturn [{ json: { output: msg } }];"
      },
