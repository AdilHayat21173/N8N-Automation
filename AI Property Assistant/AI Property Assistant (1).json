    {
      "parameters": {
        "jsCode": "// Raw output from the agent\nconst raw = $input.first().json.output;\n\n// Step 1: Clean the markdown backticks and parse JSON\nconst cleaned = raw.replace(/```json|```/g, '').trim();\nconst parsed = JSON.parse(cleaned);\n\n// Step 2: Remove the \"action\" field — keep only property filters\nconst { action, ...filters } = parsed;\n\n// Step 3: Return only meaningful fields dynamically\nreturn [{\n  json: filters\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1744,
        -768
      ],
      "id": "968ab135-bf56-41fb-b6bc-a68e8f25b009",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const weather = $input.first().json;\n\nconst location = weather.location;\nconst current = weather.current;\n\n// Air quality index labels\nconst epaLabels = {\n  1: '😊 Good',\n  2: '😐 Moderate', \n  3: '😷 Unhealthy for Sensitive Groups',\n  4: '🤢 Unhealthy',\n  5: '☠️ Very Unhealthy',\n  6: '💀 Hazardous'\n};\n\nconst epaIndex = current.air_quality?.['us-epa-index'] || 1;\n\nlet msg = `🌤️ Weather in ${location.name}, ${location.region}, ${location.country}\\n`;\nmsg += `📅 Local Time: ${location.localtime}\\n\\n`;\n\nmsg += `🌡️ Temperature: ${current.temp_c}°C / ${current.temp_f}°F\\n`;\nmsg += `🤔 Feels Like: ${current.feelslike_c}°C / ${current.feelslike_f}°F\\n`;\nmsg += `☁️ Condition: ${current.condition.text}\\n`;\nmsg += `💧 Humidity: ${current.humidity}%\\n`;\nmsg += `🌬️ Wind: ${current.wind_kph} km/h ${current.wind_dir}\\n`;\nmsg += `🌧️ Precipitation: ${current.precip_mm} mm\\n`;\nmsg += `👁️ Visibility: ${current.vis_km} km\\n`;\nmsg += `☀️ UV Index: ${current.uv}\\n`;\nmsg += `🌫️ Cloud Cover: ${current.cloud}%\\n\\n`;\n\nmsg += `💨 Air Quality:\\n`;\nmsg += `   Overall: ${epaLabels[epaIndex]}\\n`;\nmsg += `   PM2.5: ${current.air_quality.pm2_5} μg/m³\\n`;\nmsg += `   PM10: ${current.air_quality.pm10} μg/m³\\n`;\nmsg += `   CO: ${current.air_quality.co} μg/m³\\n`;\nmsg += `   O3: ${current.air_quality.o3} μg/m³\\n\\n`;\n\nmsg += `🕐 Last Updated: ${current.last_updated}`;\n\nreturn [{\n  json: {\n    output: msg\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1472,
        -1120
      ],
      "id": "bb6b9400-8477-455f-92bf-cdfede290052",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const rowData = $('Get row(s)').first().json;\nconst cityName = rowData.city || '';\nconst minPrice = rowData.min_price || 0;\nconst maxPrice = rowData.max_price || 0;\n\nlet missing = [];\nif (!cityName) missing.push('city');\nif (minPrice === 0) missing.push('minimum price');\nif (maxPrice === 0) missing.push('maximum price');\n\nconst msg = `Please add your ${missing.join(', ')} to search for properties.`;\n\nreturn [{ json: { text: msg } }];"
      },
